local Movement = {}

local RunService = game:GetService("RunService")

function Movement.FollowPath(character, points, speed)
	local hrp = character:WaitForChild("HumanoidRootPart")

	-- cleanup
	if hrp:FindFirstChild("LV") then hrp.LV:Destroy() end
	if hrp:FindFirstChild("LV_Att") then hrp.LV_Att:Destroy() end

	-- attachment
	local att = Instance.new("Attachment")
	att.Name = "LV_Att"
	att.Parent = hrp

	-- linear velocity
	local lv = Instance.new("LinearVelocity")
	lv.Name = "LV"
	lv.Attachment0 = att
	lv.MaxForce = 100000
	lv.RelativeTo = Enum.ActuatorRelativeTo.World
	lv.Parent = hrp

  -- stop spin maxing
  local align = Instance.new("AlignOrientation")
  align.Mode = Enum.OrientationAlignmentMode.OneAttachment
  align.Attachment0 = att
  align.RigidityEnabled = true
  align.MaxTorque = math.huge
  align.Responsiveness = 50
  align.Parent = hrp

	-- stop humanoid interference
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if humanoid then
		humanoid:ChangeState(Enum.HumanoidStateType.Physics)
	end

	local currentIndex = 1

	local connection
	connection = RunService.Heartbeat:Connect(function()
  local lookDir = lv.VectorVelocity
if lookDir.Magnitude > 0 then
	align.CFrame = CFrame.lookAt(hrp.Position, hrp.Position + lookDir)
end
		if not character or not character.Parent then
			connection:Disconnect()
			return
		end

		local targetPos = points[currentIndex]
		if not targetPos then
			lv.VectorVelocity = Vector3.zero
			print("finished")
			connection:Disconnect()
			return
		end

		local dir = targetPos - hrp.Position
		local dist = dir.Magnitude

		-- reached this point → go to next
		if dist < 8 then
			currentIndex += 1
			return
		end

		dir = dir.Unit
		lv.VectorVelocity = dir * speed
	end)

	return lv
end

return Movement
